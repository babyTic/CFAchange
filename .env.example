# CFAChange — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs

# API de taux de change
# Gratuit sans clé via open.er-api.com (défaut)
# Pour plus de requêtes : https://www.exchangerate-api.com (plan gratuit = 1500 req/mois)
VITE_EXCHANGE_API_KEY=

# URL de déploiement (production)
VITE_APP_URL=https://cfachange.vercel.app
